from mpi4py import MPI
from pixell import enmap, enplot, utils, reproject
from astropy.io import fits
import numpy as np
from PIL import Image
import matplotlib.pyplot as plt
import matplotlib.ticker as mtick
from astropy.cosmology import Planck18 as cosmo
import astropy.units as u
from astropy.table import Table
import time
start_time = time.time()

comm = MPI.COMM_WORLD
rank = comm.Get_rank()
size = comm.Get_size()

Nrs_stack = 30000
Nrs_substack = 50
n_substacks = Nrs_stack // Nrs_substack

if rank == 0:

    table = Table.read("/data/desi/scratch/mdoz/emucat_reduced2.ecsv", format="ascii.ecsv")
    
    emucat = table[table['ls_dr10_z_phot_mean']>0]
    
    noise = np.sqrt(emucat['solid_angle']/0.07) * emucat['stdev_residual']
    valid_flux = (noise>0) & (emucat['flux_int']>0)
    emucat = emucat[valid_flux]
    emucat['snr'] = emucat['flux_int'] / noise[valid_flux]
    
    emucat.sort('snr', reverse=True)
    
    bright = emucat['snr'] > 20
    
    z0 = emucat['ls_dr10_z_phot_mean']
    z_cut = (z0 > 0.4) & (z0 < 0.6)
    
    keep = z_cut & bright
    
    ra = emucat['ra_deg_cont'][keep]
    dec = emucat['dec_deg_cont'][keep]
    z = z0[keep]
    flux = emucat['flux_int'][keep]
    snr = emucat['snr'][keep]
    
    nsources = len(emucat[keep])
    
    print("keeping", nsources, "sources")
    
    mask = enmap.read_map("/data/desi/scratch/mdoz/wide_mask_GAL070_apod_1.50_deg_wExtended.fits")
    
    include_idx = np.arange(nsources)
    sources_overlap = []
    height,width = enmap.pixshape(mask.shape,mask.wcs)
    npix_from_edge_x = np.deg2rad(2)//width
    npix_from_edge_y = np.deg2rad(2)//height
    print("Avoiding this many pixels from the mask edges / holes (x,y):", npix_from_edge_x, npix_from_edge_y)
    
    for i_sources in range(nsources):
        coords = np.deg2rad(np.array((dec[i_sources],ra[i_sources])))
        ypix, xpix = enmap.sky2pix(mask.shape, mask.wcs, coords)
        
        left   = int(xpix - npix_from_edge_x)
        right  = int(xpix + npix_from_edge_x + 1)
        bottom = int(ypix - npix_from_edge_y)
        top    = int(ypix + npix_from_edge_y + 1)

        left, bottom = max(left, 0), max(bottom, 0)
        right, top = min(right, mask.shape[-1]), min(top, mask.shape[-2])
        
        maski = mask[bottom:top, left:right]
        if maski.size == 0:
            mean = 0.
        else:
            mean = np.mean(maski)
        if mean<1:
            continue
        else:
            sources_overlap.append(include_idx[i_sources])
        if len(sources_overlap) == Nrs_stack:
            break
    
    print('mask edges removed')
    
    ra_masked = ra[sources_overlap]
    dec_masked = dec[sources_overlap]
    z_masked = z[sources_overlap]
    snr_masked = snr[sources_overlap]
    flux_masked = flux[sources_overlap]
    n_sources = len(z_masked)
                   
    print("Number of sources remaining:", n_sources)

else:
    ra_masked = None
    dec_masked = None
    z_masked = None
    snr_masked = None
    flux_masked = None

ra_masked = comm.bcast(ra_masked, root=0)
dec_masked = comm.bcast(dec_masked, root=0)
z_masked = comm.bcast(z_masked, root=0)
snr_masked = comm.bcast(snr_masked, root=0)
flux_masked = comm.bcast(flux_masked, root=0)

# parallelize & stack

ymap = enmap.read_map("/data/desi/scratch/mdoz/ilc_SZ_yy.fits")

using_dec = dec_masked[:Nrs_stack]
using_ra = ra_masked[:Nrs_stack]

if rank == 0:
    np.random.seed(1901)
    s_idx = np.random.choice(Nrs_stack, Nrs_stack, replace=False)
    substacks = []
    for i in range(n_substacks):
        substacks.append(s_idx[i*Nrs_substack:(i+1)*Nrs_substack])
else:
    substacks = None
    
substacks = comm.bcast(substacks, root=0)
local_substacks = substacks[rank::size]

def radial_profile(image, pix_bin, rbin, valid_mask, nbins):
    
    profile = np.zeros(nbins)
    bin_cents = np.zeros(nbins)

    for i in range(nbins):
        mask = (rbin == i) & valid_mask
        profile[i] = image[mask].mean()
        bin_cents[i] = (i+0.5)*pix_bin

    return profile, bin_cents

ss_sum = []
ss_length = []
ss_rp = []

patch_size = 1 # degree
r = patch_size/2. * utils.degree
pix_bin = 2

if rank == 0:
    print(f"{n_substacks} independent realizations")
    print(f"{size} MPI ranks")

for k in range(len(local_substacks)):
    
    idx = local_substacks[k]
    patches_1x1deg = reproject.thumbnails(ymap, coords=np.deg2rad([using_dec[idx],using_ra[idx]]).T, res=0.0000454440, r=r)
    ss_sum.append(np.sum(patches_1x1deg, axis=0))
    ss_length.append(len(patches_1x1deg))

    stack_k = ss_sum[k] / ss_length[k]

    if k == 0:
        
        ny, nx = stack_k.shape
        y, x = np.indices((ny, nx))
        cy, cx = ny//2, nx//2
    
        rmap = np.sqrt((x-cx)**2 + (y-cy)**2)
        rmax = min(nx, ny)//2
        valid_mask = rmap < rmax
        rbin = (rmap / pix_bin).astype(int)
        nbins = int(rmax/pix_bin) - 1
        
    profile_k, bin_cents_k = radial_profile(stack_k, pix_bin, rbin, valid_mask, nbins)

    ss_rp.append(profile_k)

total_sum = None
total_Nrs = None
total_rpsums = None

ss_sum = np.sum(ss_sum, axis=0)
ss_length = np.sum(ss_length)

total_sum = np.zeros_like(ss_sum) if rank == 0 else None

comm.Reduce(ss_sum, total_sum, op=MPI.SUM, root=0)
total_Nrs = comm.reduce(ss_length, op=MPI.SUM, root=0)

total_rpsums = comm.gather(ss_rp, root=0)

if rank == 0:
    print(f"SNR threshold: {snr_masked[Nrs_stack-1]}")
    print(f"Flux_int threshold: {min(flux_masked[:Nrs_stack])}")

    total_stack = total_sum / total_Nrs
    
    fig, ax = plt.subplots(figsize=[5,5])
    ystack = ax.imshow(total_stack, vmin=-5e-7, vmax=-0.5e-7)
    
    nticks = 11
    
    ax.set_yticks(np.linspace(0, total_stack.shape[0],nticks))
    ax.set_xticks(np.linspace(0, total_stack.shape[0],nticks))
    ax.set_xticklabels("{:.1f}".format(tick) for tick in np.linspace(-patch_size/2., patch_size/2., nticks))
    ax.set_yticklabels("{:.1f}".format(tick) for tick in np.linspace(patch_size/2., -patch_size/2., nticks))
    ax.set_xlabel("$x$ [deg]")
    ax.set_ylabel("$y$ [deg]")
    
    plt.suptitle(f"Top SNR Radio source stack, N={Nrs_stack}")
    cbar_ax = fig.add_axes([0.95, 0.1, 0.02, 0.8])  # [left, bottom, width, height]
    
    cbar = plt.colorbar(ystack, cax=cbar_ax)
    cbar.set_label('$y$')

    time_taken = time.time() - start_time
    textdescription = f"SNR threshold: {snr_masked[Nrs_stack-1]:.3f}\nFlux_int threshold: {min(flux_masked[:Nrs_stack]):.3f}\ntime taken = {time_taken:.3f} s ({time_taken/60:.3f} min)"

    fig.text(
    0.5,          # posició horitzontal (0=esquerra, 1=dreta)
    -0.1,         # posició vertical
    textdescription,
    ha='center',
    fontsize=10)
    
    filename = f"TopSNR_stack{Nrs_stack}.png"
    plt.savefig(filename, dpi=200, bbox_inches="tight")
    plt.close()

    print('computing total radial profile...')

    all_profs = []
    
    for rankprofs in total_rpsums:
        all_profs.extend(rankprofs)

    all_profs = np.asarray(all_profs)
    mean_prof = np.mean(all_profs, axis=0)
    std_prof = np.std(all_profs, axis=0, ddof=1)
    errs_stack = std_prof*np.sqrt(Nrs_substack/Nrs_stack)
    cov = np.cov(all_profs, rowvar=False)
    cov_stack = cov*Nrs_substack/Nrs_stack
    diag = np.sqrt(np.diag(cov_stack))
    corr = cov_stack / np.outer(diag, diag)
    corr[~np.isfinite(corr)] = 0

    plt.imshow(corr)
    plt.colorbar()
    plt.savefig(f"TopSNR_corr_{Nrs_stack}_{Nrs_substack}.png")

    np.set_printoptions(threshold=np.inf)

    open("radioprof_log.txt", "a").write(f"Top SNR, N = {Nrs_stack} ({Nrs_substack} substacks)\nerrs stack = {errs_stack}\n"
                                         f"covariance matrix = {cov_stack}\n" 
                                            f"correlation = {corr}\n\n")

    full_prof, bin_cents = radial_profile(total_stack, pix_bin, rbin, valid_mask, nbins)
    
    pixwidth_arcmin  = patch_size*60/total_stack.shape[0]

    time_taken = time.time() - start_time
    textdescription = f"SNR threshold: {snr_masked[Nrs_stack-1]:.3f}\nFlux_int threshold: {min(flux_masked[:Nrs_stack]):.3f}.\nProfile of the stacking of {n_substacks} sub-stacks ({Nrs_substack} sources)"

    def atok(arcmin):
        return ((cosmo.kpc_proper_per_arcmin(0.5)*arcmin*u.arcmin).to(u.Mpc)).value #actually Mpc
    def ktoa(mpc):
        return (((mpc*u.Mpc)/cosmo.kpc_proper_per_arcmin(0.5)).to(u.arcmin)).value
    
    fig,ax = plt.subplots(figsize=[6,5])
    ax.errorbar(np.asarray(bin_cents) * pixwidth_arcmin, mean_prof, yerr=errs_stack, label='Radial profile', fmt='.')
    ax.yaxis.set_major_formatter(mtick.FormatStrFormatter('%.1e'))
    ax2 = ax.secondary_xaxis("top", functions=(atok,ktoa))
    ax2.set_xlabel("Proper Mpc from center")
    ax.set_xlabel("Arcminutes from center")
    ax.set_ylabel("Average $y$")
    ax.set_title("Top %d SNR Radio Sources" %(Nrs_stack), pad=15)
    ax.legend()
    ax.set_xlim([-.1,10])

    fig.text(
    0.5,          # horizontal (0=esq, 1=right)
    -0.1,         # vertical
    textdescription,
    ha='center',
    fontsize=10)
    
    plt.tight_layout()

    filename2 = f"TopSNR_radial_prof_{Nrs_stack}_{n_substacks}substacks.png"
    plt.savefig(filename2, dpi=200, bbox_inches="tight")
